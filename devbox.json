{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.10.7/.schema/devbox.schema.json",
  "packages": [
    "pandoc@latest",
    "yq-go@latest",
    "gnused@latest",
    "yq@latest",
    "github:sc2in/eisvogel-tex#",
    "zola@latest",
    "imagemagick@latest",
    "yj@latest"
  ],
  "shell": {
    "init_hook": [
      "echo 'Welcome to devbox!' > /dev/null"
    ],
    "scripts": {
      "build-pdfs": [
        "./pandoc.sh"
      ],
      "build-site": [
        "zola build"
      ],
      "clean": [
        "echo Cleaning the project of all build artifacts and devbox cache...",
        "rm -rf .direnv .devbox node_modules public resources internal .pnpm-store *.err *.log *.core 2>/dev/null"
      ],
      "test": [
        "zola check"
      ],
      "serve": [
        "zola serve"
      ],
      "preview": [
        "zola build --base-url http://0.0.0.0:1111",
        "devbox run build-pdfs",
        "python -m http.server 1111 -d public"
      ],
      "ci": [
        "if [ $PUBLISH == \"true\" ]; then",
        "devbox run build-site",
        "devbox run build-pdfs",
        "else",
        "devbox run build-site",
        "fi"
      ]
    }
  }
}
